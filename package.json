{
  "name": "@m1nt-s0da/dekai-data-channel",
  "version": "0.1.5",
  "private": false,
  "type": "module",
  "description": "Browser-friendly TypeScript implementation for Dekai data channels.",
  "repository": {
    "type": "git",
    "url": "git@github.com:m1nt-s0da/dakai-data-channel.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "ts-dist"
  ],
  "main": "./ts-dist/index.js",
  "types": "./ts-dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./ts-dist/index.d.ts",
      "import": "./ts-dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/clean-ts-dist.mjs && tsc -p tsconfig.build.json && node scripts/compact-ts-dist.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test:ts": "vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.25.9",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}